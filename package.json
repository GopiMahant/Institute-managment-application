{
  "name": "institute-management-app",
  "version": "1.0.0",
  "description": "Institute Management Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build:frontend && electron-builder"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.institute.app",
    "productName": "InstiManage",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "dist/api_server.exe"
    ],
    "extraResources": [
      {
        "from": "storage",
        "to": "storage",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
